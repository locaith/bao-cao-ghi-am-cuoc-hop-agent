# Frontend (copy to .env.local and Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Local development. On Vercel this must be a public HTTPS backend URL/tunnel.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:18771

# Backend (copy to backend/.env; never expose these secrets to Vercel/client code)
GOOGLE_API_KEY=YOUR_GOOGLE_AI_STUDIO_KEY
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://bao-cao-ghi-am-cuoc-hop-agent.vercel.app,https://meeting.locaith.com
PORT=18771
ALLOW_DEMO_MODE=false
